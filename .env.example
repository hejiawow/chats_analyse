# .env.example

# 虎鲸 API
HUJING_APP_ID=your_app_id
HUJING_APP_KEY=your_app_key
HUJING_API_BASE_URL=https://hj.ahujiaoyu.com:9029

# 虎鲸 Chat Pairs API（批量质检专用）
HUJING_CHAT_API_URL=http://192.168.20.217:8006
HUJING_CHAT_API_KEY=your_chat_api_key

# AI (DashScope / 阿里云百炼)
DASHSCOPE_API_KEY=sk-your-api-key
AI_MODEL=qwen-plus

# Redis
REDIS_URL=redis://localhost:6379/0

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/hujing_agent
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/hujing_agent

# JWT 认证
JWT_SECRET_KEY=change-this-to-a-random-secret-in-production
