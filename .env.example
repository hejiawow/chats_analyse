# .env.example

# 虎鲸 API
HUJING_APP_ID=your_app_id
HUJING_APP_KEY=your_app_key
HUJING_API_BASE_URL=https://hj.ahujiaoyu.com:9029

# 虎鲸文件服务基础URL（用于语音文件访问）
# 如果未设置，会从 HUJING_API_BASE_URL 自动推断
# 例如: https://hj.ahujiaoyu.com
HUJING_FILE_BASE_URL=https://hj.ahujiaoyu.com

# 虎鲸 Chat Pairs API（批量质检专用）
HUJING_CHAT_API_URL=http://192.168.20.217:8006
HUJING_CHAT_API_KEY=your_chat_api_key

# AI (DashScope / 阿里云百炼)
DASHSCOPE_API_KEY=sk-your-api-key
AI_MODEL=qwen-plus
AI_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_MAX_CONCURRENT=2
AI_SEMAPHORE_TIMEOUT=300

# ASR (Fun-ASR / 语音转文字)
# ASR服务基础URL，国内使用默认值，新加坡地域需改为: https://dashscope-intl.aliyuncs.com/api/v1
ASR_BASE_URL=https://dashscope.aliyuncs.com/api/v1
# ASR提交任务接口路径
ASR_SUBMIT_PATH=/services/audio/asr/transcription
# ASR查询任务接口路径
ASR_QUERY_PATH=/tasks
# ASR模型名称: fun-asr, paraformer-v1, qwen3-asr-flash, qwen3-asr-flash-filetrans等
ASR_MODEL=fun-asr
# ASR请求超时时间(秒)
ASR_TIMEOUT=30
# ASR轮询最大重试次数
ASR_MAX_RETRIES=60
# ASR轮询间隔(秒)
ASR_POLL_INTERVAL=2
# ASR默认语言: zh(中文), en(英文), ja(日语)等
ASR_DEFAULT_LANGUAGE=zh
# ASR音频通道ID
ASR_CHANNEL_ID=0
# ASR批量并发数（控制同时处理的语音数量，防止压垮ASR服务）
# 建议值：免费版3-5，企业版10-20，根据带宽和ASR服务承载能力调整
ASR_MAX_WORKERS=5

# Redis
REDIS_URL=redis://localhost:6379/0

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/hujing_agent
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/hujing_agent

# JWT 认证
JWT_SECRET_KEY=change-this-to-a-random-secret-in-production

# CORS（多个域名用逗号分隔）
ALLOWED_ORIGINS=http://localhost:5173
